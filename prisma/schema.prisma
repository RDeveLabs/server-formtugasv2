generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

model kelas{
  id Int @id @default(autoincrement())
  kelas String @unique
  file file[]
}

model file {
  id Int @id @default(autoincrement())
  nama String 
  nim Int
  pertemuan String
  waktu DateTime @default(now())
  kelas kelas @relation(fields: [id_kelas], references: [id])
  id_kelas Int
}